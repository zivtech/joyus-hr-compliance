---
layout: base.njk
title: Database
---

<h1>U.S. Labor Law Compliance Database</h1>
<p class="search-intro">Search federal, state, and local scheduling compliance regulations — overtime, breaks, minor labor, predictive scheduling, and more.</p>

<div class="stats-bar">
  <div class="stat-item">
    <span class="stat-number">{{ regulations | length }}</span>
    <span class="stat-label">Regulations</span>
  </div>
  <div class="stat-item">
    <span class="stat-number">{{ jurisdictions | length }}</span>
    <span class="stat-label">Jurisdictions</span>
  </div>
  <div class="stat-item">
    <span class="stat-number">{{ lawTypes | length }}</span>
    <span class="stat-label">Law Types</span>
  </div>
</div>

<div id="search"></div>
<script>
  window.addEventListener('DOMContentLoaded', () => {
    new PagefindUI({
      element: "#search",
      showSubResults: true,
      showImages: false,
      resetStyles: false
    });
  });
</script>

<h2>Regulations</h2>

<div id="facet-bar" class="facet-bar">
  <div class="facet-group" data-facet="jurisdiction">
    <button class="facet-group-toggle" aria-expanded="false">
      Jurisdiction <span class="facet-group-count"></span>
    </button>
    <div class="facet-group-panel"></div>
  </div>
  <div class="facet-group" data-facet="type">
    <button class="facet-group-toggle" aria-expanded="false">
      Law Type <span class="facet-group-count"></span>
    </button>
    <div class="facet-group-panel"></div>
  </div>
  <div class="facet-group" data-facet="status">
    <button class="facet-group-toggle" aria-expanded="false">
      Status <span class="facet-group-count"></span>
    </button>
    <div class="facet-group-panel"></div>
  </div>
</div>

<div class="facet-count">
  <span id="facet-count-text" class="facet-count-text" role="status" aria-live="polite"></span>
  <button id="facet-clear" class="facet-clear" hidden>Clear all filters</button>
</div>

<noscript>
  <p><em>Enable JavaScript for interactive filtering. All regulations are shown below.</em></p>
</noscript>

<div id="facet-empty" class="facet-empty">No regulations match the selected filters.</div>

<ul class="reg-list">
  {%- for reg in regulations | sortBy("title") %}
  <li class="reg-card"
      data-pagefind-body
      data-jurisdiction="{{ reg.jurisdiction | jurisdictionLabel }}"
      data-type="{{ reg.law_type | lawTypeLabel }}"
      data-status="{{ reg.computed_status }}">
    <div class="reg-card-header">
      <h3 class="reg-card-title"><a href="{{ ('/regulation/' + reg.id + '/') | url }}">{{ reg.title }}</a></h3>
      <span class="badge {{ reg.computed_status | statusBadgeClass }}" data-pagefind-filter="status:{{ reg.computed_status }}">{{ reg.computed_status }}</span>
    </div>
    <div class="reg-card-meta">
      <span data-pagefind-filter="jurisdiction:{{ reg.jurisdiction | jurisdictionLabel }}">{{ reg.jurisdiction | jurisdictionLabel }}</span>
      <span data-pagefind-filter="type:{{ reg.law_type | lawTypeLabel }}">{{ reg.law_type | lawTypeLabel }}</span>
      <span>{{ reg.statute_citation }}</span>
    </div>
    <p data-pagefind-meta="title:{{ reg.title }}">{{ reg.summary }}</p>
  </li>
  {%- endfor %}
</ul>
