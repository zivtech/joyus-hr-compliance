---
layout: base.njk
title: Browse by Law Type
permalink: /type/
---

<h1>Browse by Law Type</h1>
<p>Select a category to see regulations of that type across all jurisdictions.</p>

<div class="browse-grid">
  {%- set types = [] %}
  {%- for reg in regulations %}
    {%- if reg.law_type not in types %}
      {%- set types = (types.push(reg.law_type), types) %}
    {%- endif %}
  {%- endfor %}
  {%- for type in types | sort %}
  <a href="/type/{{ type }}/" class="browse-item">
    {{ type | lawTypeLabel }}
    <span class="browse-count">{{ regulations | where("law_type", type) | length }} regulations</span>
  </a>
  {%- endfor %}
</div>
