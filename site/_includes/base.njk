<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }} — HR Compliance</title>
  <meta name="description" content="{{ description | default('Searchable database of U.S. labor law scheduling compliance regulations.') }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
  <link rel="stylesheet" href="{{ '/pagefind/pagefind-ui.css' | url }}">
</head>
<body>
  <header class="site-header">
    <div class="container">
      <h1 class="site-title">
        <a href="{{ '/' | url }}">
          <span class="site-title-icon" aria-hidden="true">&#xA7;</span>
          HR Compliance
        </a>
      </h1>
      <nav class="site-nav" aria-label="Main navigation">
        <a href="{{ '/' | url }}">Database</a>
        <a href="{{ '/disclaimer/' | url }}">Disclaimer</a>
      </nav>
    </div>
  </header>
  <div class="header-accent" aria-hidden="true"></div>

  <main>
    <div class="container">
      {{ content | safe }}
    </div>
  </main>

  <footer class="site-footer">
    <div class="container">
      <p class="disclaimer-text">This database is for informational purposes only and does not constitute legal advice. Laws change frequently. Verify all information against official sources before relying on it.</p>
      <p>Last built: {{ buildDate }} &middot; <a href="{{ '/disclaimer/' | url }}">Full disclaimer</a> &middot; <a href="https://github.com/zivtech/hr-compliance">Source on GitHub</a></p>
    </div>
  </footer>

  <script src="{{ '/pagefind/pagefind-ui.js' | url }}"></script>
  <script src="{{ '/js/facets.js' | url }}"></script>
</body>
</html>
