{
  "name": "hr-compliance",
  "version": "0.1.0",
  "description": "Searchable static database of U.S. labor law scheduling compliance regulations",
  "type": "module",
  "scripts": {
    "build": "rm -rf _site && npx @11ty/eleventy && npx pagefind --site _site",
    "serve": "npx @11ty/eleventy --serve",
    "validate": "node scripts/validate.js",
    "check": "npm run validate && npm run build"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0",
    "pagefind": "^1.3.0"
  },
  "license": "Apache-2.0"
}
